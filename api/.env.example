APP_NAME=Lumen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lumen_api
DB_USERNAME=postgres
DB_PASSWORD=postgres

NOMINATIM_ENABLED=false
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_COUNTRYCODES=id
NOMINATIM_TIMEOUT=6
NOMINATIM_CONTACT=

OSRM_BASE_URL=https://router.project-osrm.org
# Vehicle mapping: mobil/motor=driving, sepeda=cycling, jalan_kaki=walking.
# Ensure the configured OSRM server supports non-driving profiles before enabling them in production.
OSRM_PROFILE=driving
OSRM_TIMEOUT=20
OSRM_MAX_WAYPOINTS=25

AUTH_TOKEN_TTL_MINUTES=1440
AUTH_TOKEN_REMEMBER_TTL_MINUTES=43200
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
